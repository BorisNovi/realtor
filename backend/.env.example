# =============================================================
# Окружение: development | staging | production
# =============================================================
ENVIRONMENT=development

# Включить режим отладки (True только для development!)
DEBUG=False

# Секретный ключ Django — генерируй командой:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# =============================================================
# Хосты и URL
# =============================================================

# Разрешённые хосты через запятую
# development: localhost,127.0.0.1
# staging:     staging.yourdomain.com
# production:  yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=

# Базовый URL бэкенда (используется для формирования ссылок на файлы)
# development: http://localhost:8000
# staging:     https://staging.yourdomain.com
# production:  https://yourdomain.com
BASE_URL=

# Разрешённые источники для CORS через запятую
# development: http://localhost:4200,http://127.0.0.1:4200
# staging:     https://staging.yourdomain.com
# production:  https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=

# =============================================================
# База данных (PostgreSQL)
# =============================================================
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
# В Docker: DATABASE_HOST=postgres (имя сервиса)
# Локально:  DATABASE_HOST=localhost
DATABASE_HOST=
DATABASE_PORT=5432

# =============================================================
# Redis
# =============================================================
# В Docker: REDIS_HOST=redis (имя сервиса)
# Локально: REDIS_HOST=localhost
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0
USE_REDIS=False
# Пароль Redis — обязательно для staging и production!
# В docker-compose: redis-server --requirepass <этот пароль>
REDIS_PASSWORD=

# =============================================================
# Email
# =============================================================
# development: django.core.mail.backends.console.EmailBackend
# production:  django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
